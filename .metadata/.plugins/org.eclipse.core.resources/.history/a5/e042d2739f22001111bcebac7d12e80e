
/*
 * ADC is connected to APB2 Bus : So APB2EN register - Enable ADC1 in adc.c
 * Search ADC in Data sheet Find the pin connected to ADC channel 1 =PA1
 * Write a function in ADC.c Pa1-adc_init
 * In that function Enable clock to GPIOA,ADC1,set mode as analog
 * Configure the Adc configurations like sampling time, length,sequence using ADc registers
 * SQ1 is first position or the first one needed to be converted
 * eg: if we have CH5,CH2,CH3
 * And I need the sequence of convversion to be CH5 - CH3 - CH2
 * then in SQ1 we need to put binary of 5 ,SQ2 = binary of 3 etc
 * here we have only 1 channel , so put 1 in SQ1
 * Configure sequence length in SQR1 register
 * we are using only 1 channel so length=1
 *
 * Enable ADC -
 * In Control register =CR2 bit 0=ADON to turn ON and Off Adc
 *
 * Write a new function to start conversion of analog value to digital
 *
 * go to control reg 2
 * SWSTART = start conversion bit
 *
 * Write a new function to read the adc value
 * to read , we need to wait till conversion ends
 *
 *
 */





#include <stdio.h>
#include "stm32f4xx.h"
#include <stdint.h>
#include "uart.h"
#include "adc.h"


uint32_t adc_val;

int main(void)
{


	UART2_tx_init();
	pa1_adc_init();
	start_conversion();



	while (1)
	{
		adc_val= adc_read();
		printf("ADV Value: %d \n\r",(int)adc_val);
	}
}
